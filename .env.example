# ═══ Combinei Bot v6 — Environment Variables ═══
# Copy to .env and fill in. NEVER commit .env to git.

PORT=3000
NODE_ENV=development

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution.com
EVOLUTION_API_KEY=your-evo-key

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# Security
WEBHOOK_SECRET=openssl-rand-hex-32
ALLOWED_ORIGINS=https://your-dashboard.com,http://localhost:5173
WEBHOOK_URL=https://your-backend.railway.app/webhook
NOTIFICATION_API_KEY=openssl-rand-hex-32

# Conversation timeout (hours before auto-cleanup)
CONVERSATION_TIMEOUT_HOURS=24
