# ═══════════════════════════════════════
# Combinei Bot — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ═══════════════════════════════════════

PORT=3000

# ─── Anthropic (Claude) — OBRIGATÓRIO ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp (Meta Cloud API) — Fase 1 ───
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=combinei-verify-2026

# ─── Google Calendar — Fase 2 ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
